# Mux (video library streaming)
# Get from https://dashboard.mux.com → Settings → Access Tokens
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret
# Optional: for membership drive video on home page — use either:
# MUX_MEMBERSHIP_DRIVE_PLAYBACK_ID=  (direct playback ID)
MUX_MEMBERSHIP_DRIVE_ASSET_ID=your-mux-membership-drive-asset-id

# Supabase (database / auth)
# Get from https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service role key (server-only; for creating users and managing events/blog/books). Same dashboard → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# No longer used: access is via profiles.roles (admin/staff). First admin: create user in Supabase Auth, then insert into profiles.
# ADMIN_EMAILS=

# Resend (contact form emails)
# Get from https://resend.com/api-keys — free tier allows 100 emails/day
RESEND_API_KEY=your-resend-api-key
# Optional: use a verified domain, e.g. "Nkata Ndi Inyom Igbo <hello@yourdomain.com>"
RESEND_FROM="Nkata Ndi Inyom Igbo <hello@yourdomain.com>"
